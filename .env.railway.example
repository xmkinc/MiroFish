# ============================================================
# Railway 环境变量配置说明
# 请在 Railway Dashboard -> Variables 面板中设置以下变量
# ============================================================

# LLM API 配置（支持 OpenAI SDK 格式的任意 LLM API）
# OpenRouter 示例：
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3.5-72b

# 阿里云百炼平台示例：
# LLM_API_KEY=your_dashscope_api_key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# OpenAI 示例：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# ===== ZEP 记忆图谱配置 =====
# 在 https://app.getzep.com/ 免费注册获取
ZEP_API_KEY=your_zep_api_key_here

# ===== 可选：加速 LLM 配置 =====
# LLM_BOOST_API_KEY=your_boost_api_key
# LLM_BOOST_BASE_URL=https://openrouter.ai/api/v1
# LLM_BOOST_MODEL_NAME=qwen/qwen3.5-7b

# ===== Flask 配置 =====
FLASK_DEBUG=False
SECRET_KEY=your-random-secret-key-here

# Railway 会自动注入 PORT 变量，无需手动设置
